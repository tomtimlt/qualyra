# ─────────────────────────────────────────────────────────────
#  Copier ce fichier :   cp .env.example .env
#  puis remplir les valeurs « À DÉFINIR ».
#  Sert à la fois à Laravel (dans le conteneur) ET à
#  l'interpolation ${...} de docker-compose.yml.
#  Ne jamais committer le .env rempli (déjà dans .gitignore).
# ─────────────────────────────────────────────────────────────

APP_NAME=Qualyra
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080      # En prod : https://ton-domaine.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
MAIL_MAILER=log

# ── Panel admin (gate /admin) ──
# À DÉFINIR : mot de passe fort (ex: openssl rand -base64 24)
VITRINE_ADMIN_PASSWORD=
VITRINE_CONTACT_EMAIL=contact@qualyra.app

# ── Umami (analytics) — à remplir APRÈS la 1re config dans l'UI Umami ──
VITRINE_UMAMI_SRC=
VITRINE_UMAMI_WEBSITE_ID=
VITRINE_UMAMI_DASHBOARD=

# ── Secrets infra docker-compose ──
# À DÉFINIR :  openssl rand -base64 40
UMAMI_APP_SECRET=
UMAMI_DB_PASSWORD=umami
